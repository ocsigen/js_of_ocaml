(install
 (section lib)
 (package wasm_of_ocaml-compiler)
 (files runtime.wasm runtime.js))

(rule
 (target runtime.wasm)
 (deps
  args
  (glob_files *.wat))
 (action
  (run
   wasmoo_util
   link
   --binaryen=-g
   --binaryen-opt=-O3
   %{target}
   %{read-lines:args})))

(rule
 (target args)
 (deps
  args.ml
  (glob_files *.wat))
 (action
  (with-stdout-to
   %{target}
   (run ocaml %{deps}))))
