(install
 (section lib)
 (package wasm_of_ocaml-compiler)
 (files
  (glob_files *.wat)
  (glob_files runtime-*.wasm)
  runtime.js))

(rule
 (target binaryen-version-check)
 (deps check_binaryen.ml (universe))
 (action
  (progn
   (run ocaml %{deps})
   (with-stdout-to
    %{target}
    (echo "ok")))))

(rule
 (target runtime-standard.wasm)
 (deps
  binaryen-version-check
  args
  c-impl.wasm
  (glob_files *.wat))
 (action
  (run
   ../../compiler/bin-wasm_of_ocaml/wasmoo_link_wasm.exe
   --binaryen=-g
   --binaryen-opt=-O3
   --set=effects=jspi
   --disable=wasi
   --allowed-imports=bindings,Math,js,wasm:js-string,wasm:text-encoder,wasm:text-decoder
   %{target}
   c:c-impl.wasm
   %{read-lines:args})))

(rule
 (target runtime-cps.wasm)
 (deps
  binaryen-version-check
  args
  c-impl.wasm
  (glob_files *.wat))
 (action
  (run
   ../../compiler/bin-wasm_of_ocaml/wasmoo_link_wasm.exe
   --binaryen=-g
   --binaryen-opt=-O3
   --set=effects=cps
   --disable=wasi
   --allowed-imports=bindings,Math,js,wasm:js-string,wasm:text-encoder,wasm:text-decoder
   %{target}
   c:c-impl.wasm
   %{read-lines:args})))

(rule
 (target runtime-wasi.wasm)
 (deps
  args
  (glob_files *.wat)
  libc.wasm
  c-impl.wasm)
 (action
  (run
   ../../compiler/bin-wasm_of_ocaml/wasmoo_link_wasm.exe
   --binaryen=-g
   --binaryen-opt=-O3
   --set=effects=disabled
   --enable=wasi
   --allowed-imports=wasi_snapshot_preview1,OCaml
   %{target}
   libc:libc.wasm
   c:c-impl.wasm
   %{read-lines:args})))

(rule
 (target runtime-cps-wasi.wasm)
 (deps
  args
  (glob_files *.wat)
  libc.wasm
  c-impl.wasm)
 (action
  (run
   ../../compiler/bin-wasm_of_ocaml/wasmoo_link_wasm.exe
