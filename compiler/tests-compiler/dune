; All test modules in this directory share one library: dune runs each source
; file as its own inline-test partition (see ppx_expect_light's
; -list-partitions/-partition), so a single library keeps test-execution
; parallelism without a library per module. New *.ml files are picked up
; automatically. Profile/version/arch gating lives in the test sources
; themselves (a floating [@@@if ...] from ppx_optcomp_light, or a per-test
; [@when ...] from ppx_expect_light).

(library
 (name jsoo_compiler_test)
 (libraries js_of_ocaml_compiler unix str jsoo_compiler_expect_tests_helper)
 (inline_tests
  ;; Depend on the profile-selected [node] wrapper (defined in the root dune's
  ;; env) so dune materialises the right one on PATH before the runner execs it
  ;; and re-runs the tests when it changes.
  (deps
   %{bin:node}
   (file %{project_root}/compiler/bin-js_of_ocaml/js_of_ocaml.exe)
   (file %{project_root}/compiler/bin-jsoo_minify/jsoo_minify.exe)))
 (flags
  (:standard -open Jsoo_compiler_expect_tests_helper))
 (preprocess
  (pps ppx_optcomp_light ppx_expect_light)))
