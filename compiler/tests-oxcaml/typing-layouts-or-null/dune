(tests
 (names atomics immediate_comparison optimized probe runtime segfault)
 (libraries ocaml_testing)
 (modes js wasm))

(rule
 (target basics.ml.corrected)
 (action
  (run node %{dep:../expect.bc.js} %{dep:basics.ml})))

(rule
 (alias runtest-js)
 (enabled_if
  %{oxcaml_supported})
 (action
  (diff basics.ml basics.ml.corrected)))

