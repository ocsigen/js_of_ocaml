; Most Unix tests here exercise primitives that the QuickJS runtime
; does not implement (caml_unix_stat, caml_unix_utimes, ...) or rely
; on Node-specific Unix.access / Unix.rename semantics. uexit
; additionally depends on Node's stdout/stderr flushing order on exit.

(tests
 (names append)
 (enabled_if
  (<> %{profile} quickjs))
 (libraries ocaml_testing unix)
 (locks append.txt)
 (modes js wasm))

(tests
 (names channel_of cmdline_prog reflector rename truncate uexit utimes)
 (enabled_if
  (<> %{profile} quickjs))
 (libraries ocaml_testing unix)
 (modes js wasm))

(tests
 (names bigarrays)
 (build_if
  (>= %{ocaml_version} 5.2))
 (libraries ocaml_testing unix)
 (modes js wasm))
