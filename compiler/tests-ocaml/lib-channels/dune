; close_in / in_channel_length / seek_in open the test binary itself
; as a regular file (Sys.argv.(0)). Under Node, jsoo's runtime resolves
; that path on the host filesystem; under QuickJS it falls back to the
; in-memory MlFakeFd at /static/, where the binary doesn't exist.
; buffered relies on Node's specific stdout/stderr flushing order at
; exit, which differs under QuickJS.

(tests
 (names close_in in_channel_length seek_in)
 (enabled_if
  (<> %{profile} quickjs))
 (libraries ocaml_testing)
 (modes js wasm))

(tests
 (names close_out)
 (libraries ocaml_testing)
 (modes js wasm)
 (action
  (run node %{test} testfile.tmp)))

(tests
 (names buffered)
 (build_if
  (>= %{ocaml_version} 4.14))
 (enabled_if
  (<> %{profile} quickjs))
 (libraries ocaml_testing)
 (action
  (pipe-outputs
   (run node %{test})
   (run cat)))
 (modes js wasm))

(tests
 (names input_lines)
 (build_if
  (>= %{ocaml_version} 5.1))
 (libraries ocaml_testing)
 (modes js wasm))

(tests
 (names bigarrays)
 (build_if
  (>= %{ocaml_version} 5.2))
 (libraries ocaml_testing)
 (modes js wasm))
