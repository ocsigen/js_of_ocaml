(tests
 (names close_out)
 (libraries ocaml_testing)
 (modes js wasm)
 (action
  (run node %{test} testfile.tmp)))

(tests
 (names buffered)
 (build_if
  (>= %{ocaml_version} 4.14))
 (enabled_if
  (<> %{profile} quickjs))
 (libraries ocaml_testing)
 (action
  (pipe-outputs
   (run node %{test})
   (run cat)))
 (modes js wasm))

