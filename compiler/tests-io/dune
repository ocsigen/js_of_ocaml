(executables
 (names cat md5)
 (modes
  js
  wasm
  (best exe)))

(rule
 (target cat-native.stdout)
 (action
  (with-stdout-to
   %{target}
   (pipe-stdout
    (run printf "echo ☠")
    (run %{dep:./cat.exe})))))

(rule
 (target cat-js.stdout)
 (action
  (with-stdout-to
   %{target}
   (pipe-stdout
    (run printf "echo ☠")
    (run node %{dep:./cat.bc.js})))))

(rule
 (target cat-wasm.stdout)
 (action
  (with-stdout-to
   %{target}
   (pipe-stdout
    (run printf "echo ☠")
    (run node %{dep:./cat.bc.wasm.js})))))

(rule
 (alias runtest-js)
 (action
  (diff cat-js.stdout cat-native.stdout)))

(rule
 (alias runtest-wasm)
 (action
  (diff cat-wasm.stdout cat-native.stdout)))

(rule
 (target md5-native.stdout)
 (action
  (with-stdout-to
   %{target}
   (progn
    (run %{dep:md5.exe} %{dep:md5.bc.js})
    (run %{dep:md5.exe} %{dep:md5.bc.js} %{dep:md5.bc.js})
    (run %{dep:md5.exe} -offset 2000 -length 4000 %{dep:md5.bc.js})
    (pipe-stdout
     (echo "tests")
     (run %{dep:md5.exe}))
    (pipe-stdout
     (echo "teststeststests")
     (run %{dep:md5.exe} -offset 5 -length 5))
    (pipe-stdout
     (echo "teststeststests")
     (run %{dep:md5.exe} -offset 2 -length 5))))))

(rule
 (target md5-js.stdout)
 (action
  (with-stdout-to
   %{target}
   (progn
    (run node %{dep:md5.bc.js} %{dep:md5.bc.js})
    (run node %{dep:md5.bc.js} %{dep:md5.bc.js} %{dep:md5.bc.js})
    (run node %{dep:md5.bc.js} -offset 2000 -length 4000 %{dep:md5.bc.js})
    (pipe-stdout
     (echo "tests")
     (run node %{dep:md5.bc.js}))
    (pipe-stdout
     (echo "teststeststests")
     (run node %{dep:md5.bc.js} -offset 5 -length 5))
    (pipe-stdout
     (echo "teststeststests")
     (run node %{dep:md5.bc.js} -offset 2 -length 5))))))

(rule
 (target md5-wasm.stdout)
 (action
  (with-stdout-to
   %{target}
   (progn
    (run node %{dep:md5.bc.wasm.js} %{dep:md5.bc.js})
    (run node %{dep:md5.bc.wasm.js} %{dep:md5.bc.js} %{dep:md5.bc.js})
    (run node %{dep:md5.bc.wasm.js} -offset 2000 -length 4000 %{dep:md5.bc.js})
    (pipe-stdout
     (echo "tests")
     (run node %{dep:md5.bc.wasm.js}))
    (pipe-stdout
     (echo "teststeststests")
     (run node %{dep:md5.bc.wasm.js} -offset 5 -length 5))
    (pipe-stdout
     (echo "teststeststests")
     (run node %{dep:md5.bc.wasm.js} -offset 2 -length 5))))))

(rule
 (alias runtest-js)
 (action
  (diff md5-js.stdout md5-native.stdout)))

(rule
 (alias runtest-wasm)
 (action
  (diff md5-wasm.stdout md5-native.stdout)))
