(executable
 (name run)
 (libraries js_of_ocaml_compiler unix str))

(rule
 (alias runtest-parser)
 (deps
  (glob_files_rec pass/*.js)
  simple.js
  package.json)
 (action
  (run ./run.exe pass)))

