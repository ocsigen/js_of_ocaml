(executables
 (names error1 error2)
 (modes exe js wasm)
 (foreign_stubs
  (language c)
  (names named_value_stubs))
 (js_of_ocaml
  (javascript_files runtime.js))
 (libraries))

(rule
 (target error1.js.actual)
 (deps error1.html)
 (alias runtest-js)
 (action
  (with-accepted-exit-codes
   2
   (with-outputs-to
    %{target}
    (run node %{dep:error1.bc.js})))))

(rule
 (target error1.wasm.js.actual)
 (deps error1.html)
 (alias runtest-wasm)
 (action
  (with-accepted-exit-codes
   2
   (with-outputs-to
    %{target}
    (run node %{dep:error1.bc.wasm.js})))))

(rule
 (target error1.exe.actual)
 (alias runtest)
 (action
  (with-accepted-exit-codes
   2
   (with-outputs-to
    %{target}
    (run %{dep:error1.exe})))))

(rule
 (alias runtest-js)
 (action
  (diff %{dep:error1.expected} %{dep:error1.js.actual})))

(rule
 (alias runtest-wasm)
 (action
  (diff %{dep:error1.expected} %{dep:error1.wasm.js.actual})))

(rule
 (alias runtest)
 (action
  (diff %{dep:error1.expected} %{dep:error1.exe.actual})))

