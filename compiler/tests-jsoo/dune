; test_sys drives the jsoo fake filesystem (Sys_js, jsoo_create_file, Unix) under
; the /static mount, which only exists on the JavaScript runtime, so it is
; js-only (never wasm, native or WASI). It also needs OCaml >= 5, gated in the
; source as a floating [@@@if] (hence ppx_optcomp_light).

(library
 (name jsoo_testsuite_sys)
 (enabled_if
  (<> %{env:JSOO_TEST_ENGINE=node} wasi))
 (modules test_sys)
 (libraries js_of_ocaml unix)
 (inline_tests
  (deps
   (sandbox preserve_file_kind))
  (modes js))
 (preprocess
  (pps ppx_optcomp_light ppx_expect_light)))

; js_of_ocaml runtime-behaviour tests with one shared signature: they use Js
; values / runtime features, so they run on the JavaScript and wasm runtimes
; only (never native or WASI). Grouped into a single library; each module covers
; one area:
;   ephemeron_data                - Js values kept live through ephemerons
;   hash_jsstring                 - JS-string hashing matches the JS runtime
;   wrap_exception                - caml_wrap_exception on thrown JS values
;   meth_call_utf8                - UTF-8 method-name resolution in caml_js_meth_call
;   test_custom_name              - custom value names
;   test_list_of_js_array         - Js array <-> list conversion
;   channel_refill                - Sys_js.set_channel_filler
;   test_nodejs_filesystem_errors - node fs error mapping (caml_sys_read_directory)

(library
 (name jsoo_testsuite_js_runtime)
 (enabled_if
  (<> %{env:JSOO_TEST_ENGINE=node} wasi))
 (modules
  ephemeron_data
  hash_jsstring
  wrap_exception
  meth_call_utf8
  test_custom_name
  test_list_of_js_array
  channel_refill
  test_nodejs_filesystem_errors)
 (libraries js_of_ocaml)
 (inline_tests
  (deps
   (sandbox preserve_file_kind))
  (modes js wasm))
 (preprocess
  (pps ppx_expect_light)))

