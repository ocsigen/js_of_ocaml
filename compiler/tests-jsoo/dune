(env
 (_
  ;; for testing
  (env-vars
   (FOO bar))))

; OxCaml-only tests sharing the same deps and gating, so they live in one
; library: test_ugeint exercises the UGEINT primitives OxCaml emits, and
; test_marshal_float32 the float32 marshalling. Both run on js, wasm and native
; — the float32 default [%expect] is the native/wasm custom-block encoding (the
; [@when js] variant carries the js encoding).

(library
 (name jsoo_testsuite_oxcaml)
 (modules test_ugeint test_marshal_float32)
 (libraries unix compiler-libs.common js_of_ocaml-compiler)
 (enabled_if %{oxcaml_supported})
 (inline_tests
  (modes js wasm best))
 (preprocess
  (pps ppx_expect_light)))

(rule
 ; Guard against future OxCaml changes peepholing UGEINT away the same
 ; way vanilla ocamlc does. If this rule fails, [test_ugeint] still
 ; passes its assertions but no longer exercises the UGEINT code path
 ; in [parse_bytecode.ml], and the regression coverage is gone.
 (alias runtest)
 (enabled_if %{oxcaml_supported})
 (deps ugeint_bytecode_probe.ml)
 (action
  (bash
   "ocamlc %{deps} -o probe.bc && dumpobj probe.bc | grep -qE '^[[:space:]]*[0-9]+[[:space:]]+UGEINT'")))

(library
 ; The #2300 regression has to digest a >2 GiB input, which takes far longer
 ; than a normal inline test (~40s in JS). It is therefore isolated in its
 ; own library and OFF BY DEFAULT: opt in with JSOO_TEST_MD5_LARGE=true, e.g.
 ; via `make test-md5-large`.
 (name jsoo_testsuite_md5_large)
 (modules test_md5_large)
 ; Off by default (the env opt-in stays in dune); the quickjs/wasi gating
 ; lives in the source as a [@when ...] predicate.
 (enabled_if %{env:JSOO_TEST_MD5_LARGE=false})
 (inline_tests
  (deps
   (sandbox preserve_file_kind))
  (modes js wasm best))
 (preprocess
  (pps ppx_expect_light)))

(library
 (name jsoo_testsuite)
 (modules
  (:standard
   \
   test_float16
   test_list_of_js_array
   test_marshal_float32
   test_md5_large
   test_ugeint
   ugeint_bytecode_probe
   test_runtime_value
   ephemeron_data
   hash_jsstring
   bigstring_kind
   wrap_exception
   meth_call_utf8
   runtime_events_register
   test_custom_name
   test_text_codec_fallback
   test_sys
   test_nodejs_filesystem_errors
   channel_refill
   test_promise
   test_lwt_promise
   test_weak_gc
   toplevel_sections))
 (libraries unix compiler-libs.common js_of_ocaml-compiler str)
 ; bigarray_stubs backs test_bigarray; its symbols are disjoint from
 ; jsoo_runtime_stubs and the C is version-agnostic.
 (foreign_stubs
  (language c)
  (names jsoo_runtime_stubs bigarray_stubs))
 (inline_tests
  (deps
   (sandbox preserve_file_kind))
  (modes js wasm best))
 (preprocess
  (pps ppx_optcomp_light ppx_expect_light)))

