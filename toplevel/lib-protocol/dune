;; Shared toplevel-result types and the host <-> worker message protocol.
;; Deliberately dependency-free so the host driver
;; (Js_of_ocaml_toplevel_worker_lwt_client) can use it without linking the
;; toplevel runtime.

(library
 (name js_of_ocaml_toplevel_protocol)
 (public_name js_of_ocaml-toplevel.protocol)
 (synopsis "Js_of_ocaml toplevel worker message protocol"))
