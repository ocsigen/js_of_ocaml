;; Host driver: drives a worker over the message protocol. Depends only on the
;; dependency-free msg library, so it does not link the toplevel runtime.

(library
 (name js_of_ocaml_toplevel_lwt)
 (public_name js_of_ocaml-toplevel.lwt)
 (optional)
 (synopsis "Js_of_ocaml toplevel async host driver")
 (libraries lwt js_of_ocaml js_of_ocaml-toplevel.msg)
 (preprocess
  (pps js_of_ocaml-ppx)))
